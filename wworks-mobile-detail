// Mobile Navigation Toggle
function toggleNav() {
  const mobileNav = document.getElementById('mobileNav');
  mobileNav.classList.toggle('open');
}

// Form Submission Handler
document.getElementById('bookingForm').addEventListener('submit', function(e) {
  e.preventDefault();
  
  // Get form data
  const formData = new FormData(this);
  const data = {
    firstName: document.getElementById('fname').value,
    lastName: document.getElementById('lname').value,
    email: document.getElementById('email').value,
    phone: document.getElementById('phone').value,
    service: document.getElementById('service').value,
    vehicle: document.getElementById('vehicle').value,
    date: document.getElementById('date').value,
    time: document.getElementById('time').value,
    address: document.getElementById('address').value,
    notes: document.getElementById('notes').value
  };
  
  // Log form data (replace with actual backend call)
  console.log('Booking Request:', data);
  
  // Show success message
  document.getElementById('bookingForm').style.display = 'none';
  document.getElementById('successMsg').style.display = 'block';
  
  // Reset form after 3 seconds
  setTimeout(() => {
    document.getElementById('bookingForm').reset();
    document.getElementById('bookingForm').style.display = 'block';
    document.getElementById('successMsg').style.display = 'none';
  }, 3000);
});

// Smooth scroll for anchor links
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
  anchor.addEventListener('click', function (e) {
    e.preventDefault();
    const target = document.querySelector(this.getAttribute('href'));
    if (target) {
      target.scrollIntoView({ behavior: 'smooth' });
      // Close mobile nav if open
      document.getElementById('mobileNav').classList.remove('open');
    }
  });
});
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --green:     #0c2b1c;
  --green-mid: #163d28;
  --gold:      #c8a135;
  --gold-lt:   #e2bc62;
  --cream:     #f7f5ef;
  --muted:     #6b6b5e;
  --border:    #dedad0;
}
html { scroll-behavior: smooth; }
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--green);
  overflow-x: hidden;
}

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 6vw;
  background: rgba(12,43,28,0.97);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(200,161,53,0.22);
}
.nav-brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
.nav-brand img { height: 48px; width: 48px; border-radius: 50%; object-fit: cover; border: 2px solid var(--gold); }
.nav-wordmark { font-family: 'Playfair Display', serif; font-size: 1.05rem; color: var(--gold); line-height: 1.15; }
.nav-wordmark small { display: block; font-family: 'DM Sans', sans-serif; font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(200,161,53,0.55); font-weight: 400; }
.nav-links { display: flex; gap: 28px; list-style: none; align-items: center; }
.nav-links a { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; color: rgba(247,245,239,0.6); transition: color 0.2s; }
.nav-links a:hover { color: var(--gold); }
.nav-cta { background: var(--gold) !important; color: var(--green) !important; padding: 9px 22px !important; border-radius: 2px; font-weight: 500 !important; }
.nav-cta:hover { background: var(--gold-lt) !important; }
.hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; background: none; border: none; }
.hamburger span { display: block; width: 24px; height: 2px; background: var(--gold); border-radius: 2px; }
.mobile-nav { display: none; position: fixed; top: 76px; left: 0; right: 0; z-index: 199; background: rgba(12,43,28,0.98); backdrop-filter: blur(16px); padding: 24px 6vw 32px; border-bottom: 1px solid rgba(200,161,53,0.2); flex-direction: column; }
.mobile-nav.open { display: flex; }
.mobile-nav a { display: block; padding: 14px 0; font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 500; text-decoration: none; color: rgba(247,245,239,0.7); border-bottom: 1px solid rgba(200,161,53,0.1); transition: color 0.2s; }
.mobile-nav a:last-child { border-bottom: none; color: var(--gold); margin-top: 8px; }
.mobile-nav a:hover { color: var(--gold); }

/* HERO */
.hero { min-height: 100vh; background: var(--green); display: grid; grid-template-columns: 1fr 1fr; padding-top: 76px; position: relative; overflow: hidden; }
.hero::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 75% 40%, rgba(200,161,53,0.08) 0%, transparent 55%); pointer-events: none; }
.hero-left { display: flex; flex-direction: column; justify-content: center; padding: 80px 4vw 80px 8vw; position: relative; z-index: 2; }
.eyebrow { font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); font-weight: 500; margin-bottom: 22px; animation: up 0.7s ease both; }
.hero-title { font-family: 'Playfair Display', serif; font-size: clamp(2.8rem, 5.5vw, 5rem); font-weight: 900; line-height: 1.0; color: #fff; animation: up 0.7s 0.08s ease both; }
.hero-title em { font-style: italic; color: var(--gold); }
.hero-sub { margin-top: 26px; font-size: 1rem; font-weight: 300; color: rgba(247,245,239,0.65); max-width: 400px; line-height: 1.75; animation: up 0.7s 0.16s ease both; }
.hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 38px; animation: up 0.7s 0.24s ease both; }
.hero-stats { display: flex; gap: 36px; margin-top: 52px; padding-top: 36px; border-top: 1px solid rgba(200,161,53,0.18); animation: up 0.7s 0.32s ease both; flex-wrap: wrap; }
.stat-num { font-family: 'Playfair Display', serif; font-size: 1.9rem; font-weight: 700; color: var(--gold); line-height: 1; }
.stat-label { font-size: 0.65rem; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(247,245,239,0.45); margin-top: 5px; }
.hero-right { display: flex; align-items: center; justify-content: center; padding: 60px 8vw 60px 4vw; position: relative; z-index: 2; animation: fadeIn 1s 0.3s ease both; }
.logo-frame { position: relative; width: clamp(240px, 32vw, 420px); }
.logo-frame img { width: 100%; border-radius: 50%; display: block; box-shadow: 0 0 80px rgba(200,161,53,0.22), 0 0 0 1px rgba(200,161,53,0.15); }
.logo-badge { position: absolute; bottom: -10px; right: -10px; background: var(--gold); color: var(--green); padding: 14px 18px; border-radius: 2px; text-align: center; }
.logo-badge strong { font-family: 'Playfair Display', serif; font-size: 1.4rem; display: block; line-height: 1; }
.logo-badge span { font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; }

/* SHARED */
section { padding: clamp(70px, 10vw, 120px) 8vw; }
.section-tag { font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); font-weight: 500; margin-bottom: 14px; }
.section-heading { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 900; line-height: 1.1; margin-bottom: 24px; }
.gold-rule { width: 44px; height: 2px; background: var(--gold); margin-bottom: 28px; }
.btn { display: inline-block; padding: 14px 32px; font-size: 0.76rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 500; text-decoration: none; border-radius: 2px; transition: all 0.22s; cursor: pointer; border: none; font-family: 'DM Sans', sans-serif; }
.btn-gold { background: var(--gold); color: var(--green); }
.btn-gold:hover { background: var(--gold-lt); }
.btn-outline { border: 1.5px solid rgba(200,161,53,0.55); color: rgba(247,245,239,0.8); background: transparent; }
.btn-outline:hover { border-color: var(--gold); color: var(--gold); }

/* ABOUT */
#about { background: var(--cream); }
.about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
.about-text p { font-size: 0.97rem; font-weight: 300; color: #4a4a3e; margin-bottom: 16px; line-height: 1.8; }
.about-img { position: relative; }
.about-img img { width: 100%; border-radius: 4px; display: block; box-shadow: 0 20px 60px rgba(12,43,28,0.15); }
.about-tag { position: absolute; bottom: -18px; left: -18px; background: var(--green); color: var(--gold); padding: 18px 22px; border-radius: 2px; }
.about-tag strong { font-family: 'Playfair Display', serif; font-size: 1.6rem; display: block; line-height: 1; }
.about-tag span { font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(200,161,53,0.65); }

/* SERVICES */
#services { background: var(--green); }
#services .section-heading { color: #fff; }
.services-intro { color: rgba(247,245,239,0.55); font-size: 0.95rem; font-weight: 300; max-width: 520px; margin-bottom: 52px; line-height: 1.8; }
.services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
.svc-card { background: var(--green-mid); padding: 38px 30px; border: 1px solid rgba(200,161,53,0.1); position: relative; overflow: hidden; transition: background 0.25s, border-color 0.25s; }
.svc-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--gold); transform: scaleX(0); transform-origin: left; transition: transform 0.3s; }
.svc-card:hover { background: #1e4a30; border-color: rgba(200,161,53,0.25); }
.svc-card:hover::before { transform: scaleX(1); }
.svc-num { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 900; color: rgba(200,161,53,0.15); line-height: 1; margin-bottom: 16px; }
.svc-name { font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 700; color: #fff; margin-bottom: 14px; line-height: 1.3; }
.svc-desc { font-size: 0.85rem; font-weight: 300; color: rgba(247,245,239,0.55); line-height: 1.75; }
.svc-tag { display: inline-block; margin-top: 18px; font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); border: 1px solid rgba(200,161,53,0.3); padding: 5px 12px; border-radius: 1px; }

/* GALLERY */
#gallery { background:#0a2218; }
#gallery .section-heading { color:#fff; }
.gallery-intro { color:rgba(247,245,239,0.5); font-size:0.93rem; font-weight:300; max-width:500px; margin:20px 0 48px; line-height:1.8; }
.gallery-grid { columns:3; column-gap:10px; }
.gallery-grid img { break-inside:avoid; margin-bottom:10px; border-radius:3px; width:100%; display:block; transition:transform 0.4s; }
.gallery-grid img:hover { transform:scale(1.03); }

/* BOOKING */
#booking { background: var(--cream); }
.booking-layout { display: grid; grid-template-columns: 1fr 1.6fr; gap: 72px; align-items: start; margin-top: 8px; }
.booking-info p { font-size: 0.93rem; font-weight: 300; color: var(--muted); line-height: 1.8; margin-bottom: 16px; }
.info-points { margin-top: 28px; display: flex; flex-direction: column; gap: 14px; }
.info-point { display: flex; gap: 14px; align-items: flex-start; }
.info-point-icon { width: 32px; height: 32px; flex-shrink: 0; background: var(--green); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; margin-top: 2px; }
.info-point-text { font-size: 0.88rem; font-weight: 300; color: var(--muted); line-height: 1.6; }
.info-point-text strong { font-weight: 500; color: var(--green); display: block; }
.booking-form { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 40px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 18px; }
.form-group { display: flex; flex-direction: column; gap: 7px; }
.form-group.full { grid-column: 1 / -1; }
label { font-size: 0.67rem; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 500; color: var(--muted); }
input, select, textarea { font-family: 'DM Sans', sans-serif; font-size: 0.93rem; font-weight: 300; border: 1.5px solid var(--border); border-radius: 2px; padding: 12px 14px; background: var(--cream); color: var(--green); transition: border-color 0.2s; outline: none; width: 100%; }
input:focus, select:focus, textarea:focus { border-color: var(--green); background: #fff; }
textarea { min-height: 100px; resize: vertical; }
.form-footer { margin-top: 24px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
.form-note { font-size: 0.75rem; color: var(--muted); font-style: italic; }
.success-msg { display: none; background: #edf7ed; border: 1.5px solid #a8d5a8; border-radius: 4px; padding: 20px 24px; text-align: center; color: #2e6b2e; font-size: 0.93rem; margin-top: 20px; }

/* CONTACT */
#contact { background: var(--green); }
#contact .section-heading { color: #fff; }
.contact-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; margin-top: 48px; }
.contact-card { background: var(--green-mid); border: 1px solid rgba(200,161,53,0.1); padding: 32px 24px; transition: background 0.2s; }
.contact-card:hover { background: #1e4a30; }
.contact-icon { font-size: 1.4rem; margin-bottom: 14px; }
.contact-lbl { font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(200,161,53,0.55); margin-bottom: 6px; }
.contact-val { font-size: 0.93rem; color: #fff; font-weight: 300; }
.contact-val a { color: var(--gold-lt); text-decoration: none; }
.contact-val a:hover { color: var(--gold); }

/* INSTAGRAM STRIP */
.insta-strip { background: #081a10; border-top: 1px solid rgba(200,161,53,0.15); padding: 48px 8vw; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 24px; }
.insta-left { display: flex; align-items: center; gap: 20px; }
.insta-icon { width: 52px; height: 52px; background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
.insta-text strong { display: block; font-family: 'Playfair Display', serif; font-size: 1.1rem; color: #fff; }
.insta-text span { font-size: 0.75rem; color: rgba(247,245,239,0.5); font-weight: 300; }

/* FOOTER */
footer { background: #060f09; color: rgba(247,245,239,0.3); text-align: center; padding: 28px 8vw; font-size: 0.75rem; letter-spacing: 0.08em; border-top: 1px solid rgba(200,161,53,0.08); }
footer span { color: var(--gold); }

/* ANIMATIONS */
@keyframes up { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

/* RESPONSIVE */
@media (max-width: 900px) {
  .hero { grid-template-columns: 1fr; }
  .hero-right { padding: 0 8vw 60px; justify-content: flex-start; }
  .logo-frame { width: clamp(200px, 55vw, 300px); }
  .about-grid { grid-template-columns: 1fr; gap: 56px; }
  .about-tag { left: 0; }
  .services-grid { grid-template-columns: 1fr 1fr; }
  .booking-layout { grid-template-columns: 1fr; gap: 40px; }
  .contact-grid { grid-template-columns: 1fr 1fr; }
  .nav-links { display: none; }
  .hamburger { display: flex; }
}
@media (max-width: 560px) {
  .services-grid { grid-template-columns: 1fr; }
  .contact-grid { grid-template-columns: 1fr; }
  .form-row { grid-template-columns: 1fr; }
  .gallery-grid { columns: 1; }
}
